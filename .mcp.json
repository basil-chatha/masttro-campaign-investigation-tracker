{
  "mcpServers": {
        "atlassian": {
            "type": "http",
            "url": "https://mcp.atlassian.com/v1/mcp"
        },
        "linear-server": {
            "type": "http",
            "url": "https://mcp.linear.app/sse"
        },
        "codex": {
            "type": "stdio",
            "command": "codex",
            "args": ["mcp-server"]
        },
        "playwright": {
            "type": "stdio",
            "command": "npx",
            "args": ["@playwright/mcp@latest"]
        },
        "exa": {
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "exa-mcp-server"],
            "env": {
                "EXA_API_KEY": "EXA_API_KEY"
            }
        }
    }
}